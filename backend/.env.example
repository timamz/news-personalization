# OpenAI
OPENAI_API_KEY=sk-your-key

# PostgreSQL (pgvector) — used by docker-compose environment overrides
DATABASE_URL=postgresql+asyncpg://news:news@localhost:5432/news

# Redis (Celery broker) — used by docker-compose environment overrides
REDIS_URL=redis://localhost:6379/0

# App
LOG_LEVEL=DEBUG
TWITTER_FETCH_TIMEOUT_SECONDS=20
TWITTER_FETCH_ATTEMPTS=3
TWITTER_LISTING_LIMIT=20
TWITTER_FETCH_RETRY_BACKOFF_SECONDS=1
TWITTER_FETCH_MAX_RATE_LIMIT_WAIT_SECONDS=30

# Models
LLM_MODEL=gpt-5.4-nano
EMBEDDING_MODEL=text-embedding-3-small
