# LLM provider (OpenAI-compatible — direct OpenAI or proxy like NeuroAPI)
OPENAI_API_KEY=sk-your-key
# OPENAI_API_BASE=https://neuroapi.host/v1  # uncomment to use NeuroAPI proxy

# PostgreSQL (pgvector) — used by docker-compose environment overrides
DATABASE_URL=postgresql+asyncpg://news:news@localhost:5432/news

# Redis (Celery broker) — used by docker-compose environment overrides
REDIS_URL=redis://localhost:6379/0

# SOCKS5 proxy for all outbound HTTP requests (optional)
# PROXY_URL=socks5://user:password@host:port

# App
LOG_LEVEL=DEBUG

# Models (LiteLLM format: provider/model)
LITELLM_MODEL=openai/gpt-5.4-nano
LITELLM_EMBEDDING_MODEL=openai/text-embedding-3-small
LITELLM_JUDGE_MODEL=openai/gpt-5.4-nano

# Per-model USD prices per 1M tokens (input and output). Every model listed in
# LITELLM_MODEL / LITELLM_JUDGE_MODEL / LITELLM_EMBEDDING_MODEL must have an
# entry; the app refuses to start otherwise so cost accounting cannot silently
# degrade to zero. Embedding models use "input" only; set "output" to 0 or the
# same value -- completion_tokens is always 0 for embeddings.
# Example values below match current NeuroAPI rates.
LLM_MODEL_PRICING_USD_PER_1M={"openai/gpt-5.4-nano":{"input":0.13,"output":1.07},"openai/text-embedding-3-small":{"input":0.07,"output":0.07}}

# Operator alerts -- when an LLM or search provider returns a usage-limit
# error (balance, auth, persistent rate-limit), the backend POSTs a short
# alert to this URL. Typically the tgbot delivery endpoint pointed at the
# admin's chat. Throttled to one alert per (provider, kind) per
# ADMIN_ALERT_THROTTLE_SECONDS to avoid flooding the chat during an outage.
# ADMIN_ALERT_WEBHOOK_URL=http://tgbot:8001/deliver/<delivery-token>/<admin-chat-id>
# ADMIN_ALERT_THROTTLE_SECONDS=1800

# When a background Celery task hits a ProviderLimitError, it retries
# every PROVIDER_FAILURE_RETRY_COUNTDOWN_SECONDS up to
# PROVIDER_FAILURE_RETRY_MAX_ATTEMPTS times. Defaults: every 30 min for 24 h.
# PROVIDER_FAILURE_RETRY_COUNTDOWN_SECONDS=1800
# PROVIDER_FAILURE_RETRY_MAX_ATTEMPTS=48

# Web search -- Yandex Cloud Search API (REST)
# Issue an API key in the Yandex Cloud console for a service account with the
# search-api.executor role. No folder ID is required for the REST endpoint;
# the key already carries the folder binding on the server side.
YANDEX_SEARCH_API_KEY=your-yandex-api-key
# SEARCH_TYPE suffix: COM (international / Yandex.com), RU, KK, TR, BY, UZ.
YANDEX_SEARCH_TYPE=COM
