# Telegram
BOT_TOKEN=123456:ABC-your-bot-token

# Backend API (Docker service name)
BACKEND_URL=http://app:8000
BACKEND_CREATE_SUBSCRIPTION_TIMEOUT_SECONDS=90

# Webhook server (receives digest deliveries from backend)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8001
WEBHOOK_PUBLIC_HOST=tgbot

# SQLite file for telegram_id -> api_key mapping
BOT_STORAGE_PATH=/home/appuser/bot_storage.db
