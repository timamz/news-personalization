# Inherited from ../backend/.env at runtime if not set here.
# Override any of them here to run the benchmark against different credentials.

# OPENAI_API_KEY=
# OPENAI_API_BASE=
# LITELLM_MODEL=openai/gpt-5.4-nano
# LITELLM_EMBEDDING_MODEL=openai/text-embedding-3-small
# LITELLM_JUDGE_MODEL=openai/gpt-5.4-nano

# Devbox Postgres (throwaway benchmark databases are created on this instance).
# BENCHMARK_PG_HOST=100.73.138.67
# BENCHMARK_PG_PORT=5432
# BENCHMARK_PG_ADMIN_USER=news
# BENCHMARK_PG_ADMIN_PASSWORD=news
# BENCHMARK_PG_ADMIN_DB=news

# Devbox Redis.
# BENCHMARK_REDIS_URL=redis://100.73.138.67:6379/5

# Model used to generate article bodies during scenario data generation
# (written once, cached to disk, committed).
# BENCHMARK_DATAGEN_MODEL=openai/gpt-5.4-nano
